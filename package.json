{
  "name": "ehealth-website",
  "version": "1.0.0",
  "description": "EHealth Hospital Management System — Nền tảng quản lý y tế đa vai trò (Bệnh nhân, Bác sĩ, Dược sĩ, Lễ tân, Quản trị viên) — đồ án tốt nghiệp",
  "author": "Nguyễn Minh Quân",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "build:prod": "NODE_ENV=production next build",
    "start:prod": "NODE_ENV=production next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "qc:all": "tsx scripts/qc/check-all.ts all",
    "qc:quick": "tsx scripts/qc/check-all.ts quick",
    "qc:static": "tsx scripts/qc/check-all.ts static",
    "qc:api": "tsx scripts/qc/check-all.ts api",
    "qc:ui": "tsx scripts/qc/check-all.ts ui"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "next": "^14.2.35",
    "next-intl": "^4.9.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.0.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.21",
    "jsdom": "^29.0.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
