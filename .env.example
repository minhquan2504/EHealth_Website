# ============================================
# E-Health Frontend Environment Variables
# Cấu hình môi trường cho ứng dụng
# ============================================

# URL của Backend API
# Development local: http://localhost:3000
# Production demo: http://160.250.186.97:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# WebSocket URL (cho real-time features như telemedicine, notifications)
# NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Google OAuth Client ID (nếu dùng đăng nhập Google)
# Lấy từ Google Cloud Console: https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# App Environment
# Giá trị: development | staging | production
NEXT_PUBLIC_ENV=development

# ============================================
# Hướng dẫn sử dụng:
# ============================================
# 1. Copy file này thành .env.local
# 2. Điền giá trị thực cho các biến
# 3. KHÔNG commit .env.local lên git
# 4. File .env.example này dùng để mô tả các biến cần có
#
# Chạy backend trước tại http://localhost:3000 (xem /Users/minhquan/EH/EHealth-Api)
# Hoặc dùng server demo http://160.250.186.97:3000
